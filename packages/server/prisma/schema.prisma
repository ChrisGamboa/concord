generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  passwordHash String
  avatarUrl    String?
  status       String?
  createdAt    DateTime @default(now())

  messages       Message[]
  ownedServers   Server[]       @relation("ServerOwner")
  serverMembers  ServerMember[]
  invites        Invite[]
  lastReads      LastRead[]
  reactions       Reaction[]
  conversations1  Conversation[]   @relation("ConvUser1")
  conversations2  Conversation[]   @relation("ConvUser2")
  directMessages  DirectMessage[]
}

model Server {
  id        String   @id @default(cuid())
  name      String
  iconUrl   String?
  ownerId   String
  createdAt DateTime @default(now())

  owner    User           @relation("ServerOwner", fields: [ownerId], references: [id])
  channels Channel[]
  roles    Role[]
  members  ServerMember[]
  invites  Invite[]
}

model Conversation {
  id           String   @id @default(cuid())
  participant1 String
  participant2 String
  createdAt    DateTime @default(now())

  user1    User              @relation("ConvUser1", fields: [participant1], references: [id])
  user2    User              @relation("ConvUser2", fields: [participant2], references: [id])
  messages DirectMessage[]

  @@unique([participant1, participant2])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  authorId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id])

  @@index([conversationId, createdAt])
}

model Reaction {
  id        String @id @default(cuid())
  messageId String
  userId    String
  emoji     String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

model LastRead {
  userId    String
  channelId String
  readAt    DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}

model Invite {
  code      String   @id
  serverId  String
  creatorId String
  maxUses   Int?
  uses      Int      @default(0)
  expiresAt DateTime?
  createdAt DateTime @default(now())

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [creatorId], references: [id])

  @@index([serverId])
}

model Channel {
  id        String      @id @default(cuid())
  serverId  String
  name      String
  type      ChannelType @default(TEXT)
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  server    Server     @relation(fields: [serverId], references: [id], onDelete: Cascade)
  messages  Message[]
  lastReads LastRead[]

  @@index([serverId, position])
}

enum ChannelType {
  TEXT
  VOICE
}

model Message {
  id        String    @id @default(cuid())
  channelId String
  authorId  String
  content   String
  createdAt DateTime  @default(now())
  editedAt  DateTime?

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [authorId], references: [id])
  reactions Reaction[]

  @@index([channelId, createdAt])
}

model Role {
  id          String @id @default(cuid())
  serverId    String
  name        String
  color       String?
  permissions Int    @default(0)
  position    Int    @default(0)

  server      Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  memberRoles MemberRole[]

  @@index([serverId, position])
}

model ServerMember {
  userId   String
  serverId String
  nickname String?
  joinedAt DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id])
  server      Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  memberRoles MemberRole[]

  @@id([userId, serverId])
}

model MemberRole {
  userId   String
  serverId String
  roleId   String

  member ServerMember @relation(fields: [userId, serverId], references: [userId, serverId], onDelete: Cascade)
  role   Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, serverId, roleId])
}
