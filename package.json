{
  "name": "concord",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hostable Discord alternative",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "electron",
      "prisma"
    ]
  },
  "scripts": {
    "dev:server": "pnpm --filter @concord/server dev",
    "dev:client": "pnpm --filter @concord/client dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "dependencies": {
    "concord": "link:"
  }
}
